        <mxCell id="Yz34H_mpVoSUahpE3R6p-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=none;" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;b&gt;相关车抵资源位素材上线已久，露出面积较小。需更新视觉稿，提升点击转化；热门话题下精选文章较长时间未维护，需下线&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;" vertex="1">
