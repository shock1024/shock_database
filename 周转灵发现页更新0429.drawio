        <mxCell id="Yz34H_mpVoSUahpE3R6p-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=none;" value="&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;问题点1：页面功能模块单一&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="33" width="267" x="-564" y="146" as="geometry" />
        </mxCell>
        <mxCell id="Yz34H_mpVoSUahpE3R6p-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=none;" value="&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 15px;&quot;&gt;&lt;b style=&quot;&quot;&gt;当前页面仅有车抵资源位，以及热门话题模块。页面功能简单，价值感低。需丰富功能模块，增加MGM揽客、微信公众号引导关注、信用风险报告、贷中提额、热门资讯等模块。&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="95" width="369" x="-564" y="179" as="geometry" />
        </mxCell>
        <mxCell id="Yz34H_mpVoSUahpE3R6p-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelBackgroundColor=none;" value="&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;问题点2：素材老化需升级&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
